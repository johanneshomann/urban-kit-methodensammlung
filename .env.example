# MongoDB connection (use service name 'mongodb' when running in Docker)
MONGODB_URI=mongodb://mongodb:27017/urban-kit

# Payload CMS secret — must be at least 32 characters
PAYLOAD_SECRET=change-this-to-a-random-secret-min-32-chars

# Public server URL (used by Payload for media URLs etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

NODE_ENV=production
